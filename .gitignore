# Ignore everything
*

# But don't ignore these folders and files
!backend/
!banking_admin/
!banking_flutter/
!banking_core_java/
!banking_core_java/src/main/resources/application.yml
banking_core_java/.env
!docs/
!docs/**
docs/*.xlsx
!.github/
!.github/**
!.gitignore
!README.md
!LICENSE

# Don't ignore files inside these folders (use recursive un-ignore)
!backend/**
!banking_admin/**
!banking_flutter/**
!banking_core_java/**

# But ignore .git in banking_flutter (if it's a submodule)
banking_flutter/.git/

# Ignore common files in all allowed folders
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
.pnpm-debug.log*

# Build outputs
build/
dist/
out/
*.build/

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Database files
*.db
*.sqlite
*.sqlite3
data/

# Logs
logs/
*.log
lerna-debug.log*

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Temporary files
*.tmp
*.temp
.cache/

# Security
*.pem
*.key
*.crt
secrets/

# Flutter specific
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
*.iml

# Ignore unrelated markdown files
backend/RENDER_ENV_VARS_GUIDE.md
backend/RENDER_QUICK_START.md
backend/DEPLOY_RENDER.md
backend/ACCOUNT_MIGRATION_GUIDE.md
banking_flutter/ios/Runner/Assets.xcassets/LaunchImage.imageset/README.md
