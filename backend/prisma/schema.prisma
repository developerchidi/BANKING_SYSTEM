// Banking System Database Schema - SQLite (Development Testing)
// Generated by Prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Role Management
model Role {
  id          String  @id @default(cuid())
  name        String  @unique // SUPER_ADMIN, ADMIN, MANAGER, TELLER, CUSTOMER_SERVICE, COMPLIANCE, AUDITOR, CUSTOMER
  displayName String // Super Admin, Admin, Manager, Teller, Customer Service, Compliance Officer, Auditor, Customer
  description String?

  // Permissions (JSON string of permission array)
  permissions String? // ["user:read", "user:write", "transaction:read", etc.]

  // Role Hierarchy
  level Int @default(0) // Higher number = more privileges

  // Status
  isActive Boolean @default(true)

  // Relationships
  userRoles UserRole[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("roles")
}

// User Role Assignment (Many-to-Many)
model UserRole {
  id     String @id @default(cuid())
  userId String
  roleId String

  // Assignment Details
  assignedBy String? // Who assigned this role
  assignedAt DateTime  @default(now())
  expiresAt  DateTime? // Optional expiration

  // Status
  isActive Boolean @default(true)

  // Relationships
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, roleId])
  @@map("user_roles")
}

// Tier Upgrade Requests
model TierUpgradeRequest {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  currentTier String // BASIC, STANDARD, PREMIUM, VIP
  targetTier  String // STANDARD, PREMIUM, VIP

  status String  @default("PENDING") // PENDING, APPROVED, REJECTED
  reason String? // User's reason for upgrade

  requestedAt DateTime  @default(now())
  reviewedAt  DateTime?
  reviewedBy  String? // Admin user ID who reviewed

  rejectionReason String? // Admin's reason for rejection

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tier_upgrade_requests")
}

// User Management
model User {
  id              String    @id @default(cuid())
  email           String    @unique
  phone           String?   @unique
  password        String
  firstName       String
  lastName        String
  middleName      String?
  dateOfBirth     DateTime?
  gender          String? // MALE, FEMALE, OTHER
  nationality     String?
  displayCurrency String?   @default("USD")

  // KYC & Verification
  isEmailVerified Boolean @default(false)
  isPhoneVerified Boolean @default(false)
  isKycVerified   Boolean @default(false)
  kycStatus       String  @default("PENDING") // PENDING, UNDER_REVIEW, APPROVED, REJECTED, EXPIRED
  kycDocuments    String? // JSON string of document URLs and metadata

  // KYC Admin Fields
  kycApprovedAt  DateTime?
  kycApprovedBy  String? // Admin user ID who approved
  kycRejectedAt  DateTime?
  kycRejectedBy  String? // Admin user ID who rejected
  kycReviewNotes String? // Admin review notes

  // Security
  twoFactorEnabled    Boolean   @default(false)
  twoFactorSecret     String?
  twoFactorMethod     String? // SMS, EMAIL, APP
  lastLoginAt         DateTime?
  lastLoginIp         String?
  isActive            Boolean   @default(true)
  isLocked            Boolean   @default(false)
  lockedUntil         DateTime?
  failedLoginAttempts Int       @default(0)

  // Profile
  profilePicture String?
  address        String? // JSON string of full address object
  occupation     String?
  monthlyIncome  Float?
  accountTier    String  @default("BASIC") // BASIC, STANDARD, PREMIUM, VIP

  // Relationships
  accounts              Account[]
  transactions          Transaction[]
  cards                 Card[]
  loans                 Loan[]
  auditLogs             AuditLog[]
  loginSessions         LoginSession[]
  userProfile           UserProfile?
  employmentInfo        EmploymentInfo?
  securityInfo          SecurityInfo?
  userDocuments         UserDocument[]
  loginHistory          LoginHistory[]
  passwordResets        PasswordReset[]
  emailVerifications    EmailVerification[]
  twoFactorCodes        TwoFactorCode[]
  userRoles             UserRole[]
  kycRequests           KYCRequest[]
  termsAcceptances      TermsAcceptance[]
  interests             Interest[]
  tierUpgradeRequests   TierUpgradeRequest[]
  sentNotifications     Notification[]       @relation("SentNotifications")
  receivedNotifications Notification[]       @relation("ReceivedNotifications")

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// KYC Requests
model KYCRequest {
  id           String @id @default(cuid())
  userId       String
  documentType String // CCCD, CMND, PASSPORT
  status       String @default("PENDING") // PENDING, APPROVED, REJECTED, EXPIRED

  // Document Images (Base64 encoded)
  frontImage  String
  backImage   String
  selfieImage String

  // Extracted Data (JSON)
  extractedData String // JSON string containing extracted information

  // Metadata
  submittedAt     DateTime  @default(now())
  reviewedAt      DateTime?
  reviewedBy      String?
  rejectionReason String?

  // Audit fields
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Indexes for performance
  @@index([userId, status])
  @@index([status, submittedAt])
  @@index([submittedAt])
  @@map("kyc_requests")
}

// Enhanced User Profile
model UserProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  // Personal Information
  idNumber     String? // CMND/CCCD
  idType       String? // CMND, CCCD, PASSPORT
  idIssueDate  DateTime?
  idIssuePlace String?
  idExpiryDate DateTime?

  // Student Information
  studentId String? @unique
  cohort    String?
  school    String?

  // Address Information
  currentAddress   String?
  permanentAddress String?
  emergencyContact String?
  emergencyPhone   String?

  // Additional Info
  maritalStatus  String?
  dependents     Int?
  educationLevel String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_profiles")
}

// Employment Information
model EmploymentInfo {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  // Employment Details
  employmentStatus String? // EMPLOYED, SELF_EMPLOYED, UNEMPLOYED, STUDENT, RETIRED
  employerName     String?
  employerAddress  String?
  employerPhone    String?
  jobTitle         String?
  department       String?
  employmentDate   DateTime?

  // Financial Information
  annualIncome                Float?
  sourceOfFunds               String? // SALARY, BUSINESS, INVESTMENT, INHERITANCE, OTHER
  expectedMonthlyTransactions Float?

  // Business Info (if self-employed)
  businessName    String?
  businessType    String?
  businessAddress String?
  businessLicense String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("employment_info")
}

// Security Information
model SecurityInfo {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  // Security Questions
  securityQuestions String? // JSON string of questions and answers

  // Device Management
  trustedDevices String? // JSON array of trusted device info
  lastDeviceInfo String? // JSON of last login device

  // Security Settings
  passwordLastChanged   DateTime?
  requirePasswordChange Boolean   @default(false)
  sessionTimeout        Int? // in minutes

  // Transaction PIN (hashed, never store plaintext)
  transactionPinHash String?
  pinUpdatedAt       DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("security_info")
}

// User Documents
model UserDocument {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  // Document Information
  documentType String // ID_CARD, PROOF_OF_ADDRESS, PROOF_OF_INCOME, SELFIE, SIGNATURE
  documentUrl  String
  documentName String
  fileSize     Int?
  mimeType     String?
  idNumber     String? // Số giấy tờ (CCCD/Passport)

  // Verification Status
  verificationStatus String    @default("PENDING") // PENDING, APPROVED, REJECTED
  verificationNotes  String?
  verifiedBy         String?
  verifiedAt         DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_documents")
}

// Login History
model LoginHistory {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  // Login Information
  loginTime     DateTime @default(now())
  loginLocation String?
  ipAddress     String?
  userAgent     String?
  deviceInfo    String? // JSON string of device details
  success       Boolean  @default(true)

  // Additional Info
  failureReason String?
  twoFactorUsed Boolean @default(false)

  @@map("login_history")
}

// Account Management
model Account {
  id               String @id @default(cuid())
  accountNumber    String @unique
  accountType      String // CHECKING, SAVINGS, BUSINESS, JOINT, STUDENT
  accountName      String
  currency         String @default("VND")
  balance          Float  @default(0)
  availableBalance Float  @default(0)

  // Account Settings
  isActive     Boolean @default(true)
  isFrozen     Boolean @default(false)
  dailyLimit   Float?
  monthlyLimit Float?

  // Interest (for savings accounts)
  interestRate     Float?
  lastInterestDate DateTime?

  // Relationships
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Transactions
  sentTransactions     Transaction[] @relation("SenderAccount")
  receivedTransactions Transaction[] @relation("ReceiverAccount")

  cards         Card[]
  loans         Loan[]
  beneficiaries Beneficiary[]
  interests     Interest[]
  ledgerEntries LedgerEntry[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("accounts")
}

// Transaction Management
model Transaction {
  id                String @id @default(cuid())
  transactionNumber String @unique
  type              String // TRANSFER, DEPOSIT, WITHDRAWAL, BILL_PAYMENT, CARD_PAYMENT, LOAN_PAYMENT, INTEREST_CREDIT, FEE_DEBIT
  category          String // INTERNAL_TRANSFER, EXTERNAL_TRANSFER, BILL_PAYMENT, etc.
  amount            Float
  fee               Float  @default(0)
  currency          String @default("VND")

  // Source information
  sourceType  String  @default("INTERNAL") // SYSTEM, INTERNAL, EXTERNAL
  initiatedBy String? // admin user id or 'SYSTEM_JOB'
  reason      String?
  metadata    String? // JSON

  // Transaction Details
  description String?
  reference   String?
  status      String  @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED, CANCELLED, REVERSED

  // Security & Idempotency
  idempotencyKey     String?   @unique // Prevent duplicate transactions
  cancelledAt        DateTime?
  cancellationReason String?
  failedAt           DateTime?
  failureReason      String?

  // Account Information
  senderAccountId String?
  senderAccount   Account? @relation("SenderAccount", fields: [senderAccountId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  receiverAccountId String?
  receiverAccount   Account? @relation("ReceiverAccount", fields: [receiverAccountId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // External Transfer Info
  externalBankCode      String?
  externalAccountNumber String?
  externalAccountName   String?

  // User who initiated
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Bill Payment Info
  billProvider      String?
  billAccountNumber String?

  // Processing Info
  processedAt DateTime?

  // Batch Processing
  batchId String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  ledgerEntries LedgerEntry[]

  @@map("transactions")
}

// General Ledger Entries for double-entry bookkeeping
model LedgerEntry {
  id            String   @id @default(cuid())
  transactionId String
  accountId     String? // nullable for SYSTEM_LEDGER side
  ledgerAccount String // SYSTEM_LEDGER, CASH, FEES, etc.
  entryType     String // DEBIT or CREDIT
  amount        Float
  currency      String   @default("VND")
  createdAt     DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  account     Account?    @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([transactionId])
  @@index([accountId])
  @@map("ledger_entries")
}

// Card Management
model Card {
  id          String @id @default(cuid())
  cardNumber  String @unique
  cardType    String // DEBIT, CREDIT, PREPAID
  cardBrand   String // VISA, MASTERCARD, AMERICAN_EXPRESS, DISCOVER
  expiryMonth Int
  expiryYear  Int
  cvv         String // Encrypted

  // Card Details
  cardholderName String
  isActive       Boolean @default(true)
  isBlocked      Boolean @default(false)
  blockReason    String?

  // Limits
  dailyLimit    Float?
  monthlyLimit  Float?
  atmDailyLimit Float?

  // PIN
  pinHash        String?
  pinAttempts    Int       @default(0)
  pinLockedUntil DateTime?

  // Relationships
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cards")
}

// Loan Management
model Loan {
  id           String @id @default(cuid())
  loanNumber   String @unique
  loanType     String // PERSONAL, HOME, AUTO, BUSINESS, EDUCATION, CREDIT_LINE
  amount       Float
  interestRate Float
  termMonths   Int

  // Loan Status
  status          String    @default("PENDING") // PENDING, APPROVED, ACTIVE, PAID_OFF, DEFAULTED
  disbursedAmount Float?
  disbursedAt     DateTime?

  // Payment Information
  monthlyPayment   Float?
  totalInterest    Float?
  remainingBalance Float?
  nextPaymentDate  DateTime?

  // Relationships
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("loans")
}

// Audit Logging
model AuditLog {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Audit Information
  action     String // LOGIN, LOGOUT, TRANSACTION, ACCOUNT_UPDATE, etc.
  resource   String? // What resource was affected
  resourceId String? // ID of the affected resource
  details    String? // JSON string with additional details

  // Context
  ipAddress String?
  userAgent String?
  sessionId String?

  // Timestamps
  createdAt DateTime @default(now())

  @@map("audit_logs")
}

// Login Sessions
model LoginSession {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  // Session Information
  sessionToken String   @unique
  refreshToken String?  @unique
  expiresAt    DateTime
  isActive     Boolean  @default(true)

  // Device Information
  deviceInfo String? // JSON string of device details
  ipAddress  String?
  userAgent  String?
  location   String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("login_sessions")
}

// Blacklisted Tokens
model BlacklistedToken {
  id        String   @id @default(cuid())
  token     String   @unique
  type      String   @default("ACCESS") // ACCESS, REFRESH
  expiresAt DateTime

  // Timestamps
  createdAt DateTime @default(now())

  @@map("blacklisted_tokens")
}

// Beneficiary Management
model Beneficiary {
  id        String  @id @default(cuid())
  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Beneficiary Information
  name          String
  accountNumber String
  bankCode      String?
  bankName      String?
  relationship  String? // FAMILY, FRIEND, BUSINESS, OTHER

  // Transfer Limits
  dailyLimit   Float?
  monthlyLimit Float?

  // Status
  isActive   Boolean @default(true)
  isVerified Boolean @default(false)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("beneficiaries")
}

// Terms Agreement Tracking
model TermsAcceptance {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  // Terms Information
  termsVersion String // e.g., "1.0", "2.1"
  termsType    String // "REGISTRATION", "PRIVACY_POLICY", "TERMS_OF_SERVICE"
  acceptedAt   DateTime @default(now())
  ipAddress    String?
  userAgent    String?

  // Additional Info
  acceptanceMethod String? // "WEB", "MOBILE", "API"
  deviceInfo       String? // JSON string of device details

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("terms_acceptances")
}

// Vanity Numbers Inventory (Admin controlled marketplace)
model VanityNumber {
  id             String    @id @default(cuid())
  number         String    @unique
  tier           String // VIP, PREMIUM, STANDARD
  basePrice      Int       @default(0)
  status         String    @default("AVAILABLE") // AVAILABLE, HELD, SOLD
  heldUntil      DateTime?
  listedByUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("vanity_numbers")
}

// Password Reset Tokens
model PasswordReset {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  // Token Information
  token     String    @unique
  expiresAt DateTime
  isUsed    Boolean   @default(false)
  usedAt    DateTime?

  // Timestamps
  createdAt DateTime @default(now())

  @@map("password_resets")
}

// Email Verification Tokens
model EmailVerification {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  // Token Information
  token     String    @unique
  expiresAt DateTime
  isUsed    Boolean   @default(false)
  usedAt    DateTime?

  // Timestamps
  createdAt DateTime @default(now())

  @@map("email_verifications")
}

// Two-Factor Authentication Codes
model TwoFactorCode {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  // Code Information
  code      String
  expiresAt DateTime
  used      Boolean   @default(false)
  usedAt    DateTime?

  // Timestamps
  createdAt DateTime @default(now())

  @@map("two_factor_codes")
}

// Interest Calculation and History
model Interest {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  // Interest Details
  interestType    String // SAVINGS, TERM_DEPOSIT, COMPOUND
  interestRate    Float // Annual interest rate (e.g., 6.0 for 6%)
  principalAmount Float // Amount that earned interest
  interestAmount  Float // Interest earned
  totalAmount     Float // Principal + Interest

  // Calculation Period
  calculationDate DateTime // When interest was calculated
  periodStart     DateTime // Start of interest period
  periodEnd       DateTime // End of interest period

  // Status
  status   String    @default("PENDING") // PENDING, POSTED, FAILED
  postedAt DateTime? // When interest was added to account

  // Transaction Reference
  transactionId String? // Reference to the interest transaction

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("interests")
}

// Interest Rate Configuration
model InterestRate {
  id String @id @default(cuid())

  // Rate Details
  accountType    String // SAVINGS, TERM_DEPOSIT_3M, TERM_DEPOSIT_6M, TERM_DEPOSIT_12M, TERM_DEPOSIT_24M
  tier           String @default("STANDARD") // STANDARD, PREMIUM, VIP
  annualRate     Float // Annual interest rate percentage
  minimumBalance Float  @default(0) // Minimum balance to earn interest

  // Effective Period
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime? // null means indefinite

  // Status
  isActive Boolean @default(true)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([accountType, tier])
  @@map("interest_rates")
}

// System Notifications/Announcements
model Notification {
  id String @id @default(cuid())

  // Content
  title   String // Tiêu đề thông báo
  content String @db.Text // Nội dung thông báo

  // Sender (người tạo thông báo)
  senderId String // User ID của người tạo
  sender   User   @relation("SentNotifications", fields: [senderId], references: [id])

  // Receiver (người nhận - có thể là 1 hoặc nhiều)
  receiverId String // User ID của người nhận
  receiver   User   @relation("ReceivedNotifications", fields: [receiverId], references: [id])

  // Metadata
  type     String  @default("SYSTEM") // SYSTEM, KYC, TRANSACTION, ANNOUNCEMENT, SECURITY
  priority String  @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  category String? // Optional category for grouping

  // Status
  isRead Boolean   @default(false)
  readAt DateTime?

  // Related data (optional - để link với các entity khác)
  relatedType String? // TRANSACTION, KYC_REQUEST, LOAN, etc.
  relatedId   String? // ID của entity liên quan

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Indexes
  @@index([receiverId, isRead])
  @@index([receiverId, createdAt])
  @@index([senderId])
  @@index([type])
  @@map("notifications")
}
