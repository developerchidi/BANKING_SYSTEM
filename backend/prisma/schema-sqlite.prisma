// Banking System Database Schema - SQLite (Development Testing)
// Generated by Prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// User Management
model User {
  id              String    @id @default(cuid())
  email           String    @unique
  phone           String?   @unique
  password        String
  firstName       String
  lastName        String
  middleName      String?
  dateOfBirth     DateTime?
  gender          String?   // MALE, FEMALE, OTHER
  nationality     String?
  
  // KYC & Verification
  isEmailVerified Boolean   @default(false)
  isPhoneVerified Boolean   @default(false)
  isKycVerified   Boolean   @default(false)
  kycStatus       String    @default("PENDING") // PENDING, UNDER_REVIEW, APPROVED, REJECTED, EXPIRED
  kycDocuments    String?   // JSON string of document URLs and metadata
  
  // Security
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?
  twoFactorMethod  String?  // SMS, EMAIL, APP
  lastLoginAt      DateTime?
  lastLoginIp      String?
  isActive         Boolean   @default(true)
  isLocked         Boolean   @default(false)
  lockedUntil      DateTime?
  failedLoginAttempts Int       @default(0)
  
  // Profile
  profilePicture   String?
  address          String?   // JSON string of full address object
  occupation       String?
  monthlyIncome    Float?
  
  // Relationships
  accounts         Account[]
  transactions     Transaction[]
  cards            Card[]
  loans            Loan[]
  auditLogs        AuditLog[]
  loginSessions    LoginSession[]
  userProfile      UserProfile?
  employmentInfo   EmploymentInfo?
  securityInfo     SecurityInfo?
  userDocuments    UserDocument[]
  loginHistory     LoginHistory[]
  
  // Timestamps
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  
  @@map("users")
}

// Enhanced User Profile
model UserProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  
  // Personal Information
  idNumber        String?   // CMND/CCCD
  idType          String?   // CMND, CCCD, PASSPORT
  idIssueDate     DateTime?
  idIssuePlace    String?
  idExpiryDate    DateTime?
  
  // Address Information
  currentAddress  String?
  permanentAddress String?
  emergencyContact String?
  emergencyPhone  String?
  
  // Additional Info
  maritalStatus   String?
  dependents      Int?
  educationLevel  String?
  
  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@map("user_profiles")
}

// Employment Information
model EmploymentInfo {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  
  // Employment Details
  employmentStatus String?  // EMPLOYED, SELF_EMPLOYED, UNEMPLOYED, STUDENT, RETIRED
  employerName    String?
  employerAddress String?
  employerPhone   String?
  jobTitle        String?
  department      String?
  employmentDate  DateTime?
  
  // Financial Information
  annualIncome    Float?
  sourceOfFunds   String?   // SALARY, BUSINESS, INVESTMENT, INHERITANCE, OTHER
  expectedMonthlyTransactions Float?
  
  // Business Info (if self-employed)
  businessName    String?
  businessType    String?
  businessAddress String?
  businessLicense String?
  
  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@map("employment_info")
}

// Security Information
model SecurityInfo {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  
  // Security Questions
  securityQuestions String? // JSON string of questions and answers
  
  // Device Management
  trustedDevices  String?   // JSON array of trusted device info
  lastDeviceInfo  String?   // JSON of last login device
  
  // Security Settings
  passwordLastChanged DateTime?
  requirePasswordChange Boolean @default(false)
  sessionTimeout   Int?     // in minutes
  
  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@map("security_info")
}

// User Documents
model UserDocument {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  
  // Document Information
  documentType    String    // ID_CARD, PROOF_OF_ADDRESS, PROOF_OF_INCOME, SELFIE, SIGNATURE
  documentUrl     String
  documentName    String
  fileSize        Int?
  mimeType        String?
  
  // Verification Status
  verificationStatus String @default("PENDING") // PENDING, APPROVED, REJECTED
  verificationNotes String?
  verifiedBy       String?
  verifiedAt       DateTime?
  
  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@map("user_documents")
}

// Login History
model LoginHistory {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  
  // Login Information
  loginTime       DateTime  @default(now())
  loginLocation   String?
  ipAddress       String?
  userAgent       String?
  deviceInfo      String?   // JSON string of device details
  success         Boolean   @default(true)
  
  // Additional Info
  failureReason   String?
  twoFactorUsed   Boolean   @default(false)
  
  @@map("login_history")
}

// Account Management
model Account {
  id              String      @id @default(cuid())
  accountNumber   String      @unique
  accountType     String      // CHECKING, SAVINGS, BUSINESS, JOINT, STUDENT
  accountName     String
  currency        String      @default("USD")
  balance         Float       @default(0)
  availableBalance Float      @default(0)
  
  // Account Settings
  isActive        Boolean     @default(true)
  isFrozen        Boolean     @default(false)
  dailyLimit      Float?
  monthlyLimit    Float?
  
  // Interest (for savings accounts)
  interestRate    Float?
  lastInterestDate DateTime?
  
  // Relationships
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  // Transactions
  sentTransactions     Transaction[] @relation("SenderAccount")
  receivedTransactions Transaction[] @relation("ReceiverAccount")
  
  cards           Card[]
  loans           Loan[]
  beneficiaries   Beneficiary[]
  
  // Timestamps
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  @@map("accounts")
}

// Transaction Management
model Transaction {
  id                String    @id @default(cuid())
  transactionNumber String    @unique
  type              String    // TRANSFER, DEPOSIT, WITHDRAWAL, BILL_PAYMENT, CARD_PAYMENT, LOAN_PAYMENT, INTEREST_CREDIT, FEE_DEBIT
  category          String    // INTERNAL_TRANSFER, EXTERNAL_TRANSFER, BILL_PAYMENT, etc.
  amount            Float
  fee               Float     @default(0)
  currency          String    @default("USD")
  
  // Transaction Details
  description       String?
  reference         String?
  status            String    @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED, CANCELLED, REVERSED
  
  // Account Information
  senderAccountId   String?
  senderAccount     Account?  @relation("SenderAccount", fields: [senderAccountId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  receiverAccountId String?
  receiverAccount   Account?  @relation("ReceiverAccount", fields: [receiverAccountId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  // External Transfer Info
  externalBankCode  String?
  externalAccountNumber String?
  externalAccountName   String?
  
  // User who initiated
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  // Bill Payment Info
  billProvider      String?
  billAccountNumber String?
  
  // Processing Info
  processedAt       DateTime?
  failureReason     String?
  
  // Batch Processing
  batchId           String?
  
  // Timestamps
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  @@map("transactions")
}

// Card Management
model Card {
  id              String    @id @default(cuid())
  cardNumber      String    @unique
  cardType        String    // DEBIT, CREDIT, PREPAID
  cardBrand       String    // VISA, MASTERCARD, AMERICAN_EXPRESS, DISCOVER
  expiryMonth     Int
  expiryYear      Int
  cvv             String    // Encrypted
  
  // Card Details
  cardholderName  String
  isActive        Boolean   @default(true)
  isBlocked       Boolean   @default(false)
  blockReason     String?
  
  // Limits
  dailyLimit      Float?
  monthlyLimit    Float?
  atmDailyLimit   Float?
  
  // PIN
  pinHash         String?
  pinAttempts     Int       @default(0)
  pinLockedUntil  DateTime?
  
  // Relationships
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  accountId       String
  account         Account   @relation(fields: [accountId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@map("cards")
}

// Loan Management
model Loan {
  id              String     @id @default(cuid())
  loanNumber      String     @unique
  loanType        String     // PERSONAL, HOME, AUTO, BUSINESS, EDUCATION, CREDIT_LINE
  amount          Float
  interestRate    Float
  termMonths      Int
  
  // Loan Status
  status          String     @default("PENDING") // PENDING, APPROVED, ACTIVE, PAID_OFF, DEFAULTED
  disbursedAmount Float?
  disbursedAt     DateTime?
  
  // Payment Information
  monthlyPayment  Float?
  totalInterest   Float?
  remainingBalance Float?
  nextPaymentDate DateTime?
  
  // Relationships
  userId          String
  user            User       @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  accountId       String
  account         Account    @relation(fields: [accountId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  // Timestamps
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  
  @@map("loans")
}

// Audit Logging
model AuditLog {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  // Audit Information
  action          String    // LOGIN, LOGOUT, TRANSACTION, ACCOUNT_UPDATE, etc.
  resource        String?   // What resource was affected
  resourceId      String?   // ID of the affected resource
  details         String?   // JSON string with additional details
  
  // Context
  ipAddress       String?
  userAgent       String?
  sessionId       String?
  
  // Timestamps
  createdAt       DateTime  @default(now())
  
  @@map("audit_logs")
}

// Login Sessions
model LoginSession {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  
  // Session Information
  sessionToken    String    @unique
  refreshToken    String?   @unique
  expiresAt       DateTime
  isActive        Boolean   @default(true)
  
  // Device Information
  deviceInfo      String?   // JSON string of device details
  ipAddress       String?
  userAgent       String?
  location        String?
  
  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@map("login_sessions")
}

// Blacklisted Tokens
model BlacklistedToken {
  id              String    @id @default(cuid())
  token           String    @unique
  type            String    @default("ACCESS") // ACCESS, REFRESH
  expiresAt       DateTime
  
  // Timestamps
  createdAt       DateTime  @default(now())
  
  @@map("blacklisted_tokens")
}

// Beneficiary Management
model Beneficiary {
  id              String    @id @default(cuid())
  accountId       String
  account         Account   @relation(fields: [accountId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  // Beneficiary Information
  name            String
  accountNumber   String
  bankCode        String?
  bankName        String?
  relationship    String?   // FAMILY, FRIEND, BUSINESS, OTHER
  
  // Transfer Limits
  dailyLimit      Float?
  monthlyLimit    Float?
  
  // Status
  isActive        Boolean   @default(true)
  isVerified      Boolean   @default(false)
  
  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@map("beneficiaries")
} 